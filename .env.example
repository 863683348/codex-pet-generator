# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (fallback image provider)
OPENAI_API_KEY=sk-your-key
OPENAI_IMAGE_MODEL=gpt-image-1

# Bailian / Qwen-Image (preferred image provider)
BAILIAN_API_KEY=sk-your-bailian-key
BAILIAN_IMAGE_MODEL=qwen-image-2.0
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
IMAGE_PROVIDER=bailian

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog (user analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Creem (payment)
CREEM_API_KEY=sk_your-creem-api-key
CREEM_PRO_PRICE_ID=price_your-pro-price-id
CREEM_UNLIMITED_PRICE_ID=price_your-unlimited-price-id
CREEM_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
