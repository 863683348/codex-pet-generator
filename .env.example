# ============================================
# Codex Pet Generator — Railway 环境变量清单
# 在 Railway 控制台 → 你的服务 → Variables 中逐项填入
# 复制本文件内容到 Railway Variables，把 <...> 占位符换成真实值
# 真实值见本地 .env.local（不要提交到仓库！）
# ============================================

# ---------- Supabase（必填，真实生成链路依赖） ----------
# 从本地 .env.local 复制，以下为占位符示例
NEXT_PUBLIC_SUPABASE_URL=<你的 SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<你的 SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<你的 SUPABASE_SERVICE_ROLE_KEY>

# ---------- 图像生成 Provider（必填） ----------
# 可选值: bailian | openai
IMAGE_PROVIDER=bailian

# 百炼 / 通义千问（IMAGE_PROVIDER=bailian 时必填）
BAILIAN_API_KEY=<你的 BAILIAN_API_KEY>
BAILIAN_IMAGE_MODEL=qwen-image-2.0
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# OpenAI（IMAGE_PROVIDER=openai 时填，本项目默认走百炼，留空即可）
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# ---------- 应用 ----------
# 部署后 Railway 会给你一个 *.up.railway.app 域名，填到这里
NEXT_PUBLIC_APP_URL=<你的 RAILWAY 域名，例如 https://codex-pet.up.railway.app>

# ---------- PostHog 分析（可选） ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Creem 支付（可选，不用付费功能可留空） ----------
CREEM_API_KEY=
CREEM_PRO_PRICE_ID=
CREEM_UNLIMITED_PRICE_ID=
CREEM_WEBHOOK_SECRET=
